[Unit]
Description=Polymarket Paper Trading Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__PROJECT_DIR__
Environment=PYTHONUNBUFFERED=1
Environment=PORT=5000
ExecStart=__PROJECT_DIR__/venv/bin/python -u src/dashboard.py
Restart=always
RestartSec=10
StandardOutput=append:__PROJECT_DIR__/logs/dashboard.log
StandardError=append:__PROJECT_DIR__/logs/dashboard.error.log

[Install]
WantedBy=multi-user.target
